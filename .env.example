# ── 数据库 ─────────────────────────────────────────────────────────────────────
# docker-compose 默认值（docker-compose up -d 启动后直接可用）
DATABASE_URL=postgresql://doudizhu:doudizhu_dev@localhost:5432/doudizhu

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Solana 网络 ────────────────────────────────────────────────────────────────
SOLANA_RPC=https://api.devnet.solana.com

# ── 服务器 ─────────────────────────────────────────────────────────────────────
WS_PORT=8080
# 中继器钱包（devnet 测试用 ~/.config/solana/id.json 即可）
RELAY_KEYPAIR_PATH=~/.config/solana/id.json

# ── 前端 ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_SERVER_URL=http://localhost:8080

# ── E2E 测试钱包（devnet，绝不提交真实私钥）────────────────────────────────────
# 格式：Keypair secretKey 的 JSON 数字数组，例如 [1,2,3,...,64]
# 生成方式：solana-keygen new --outfile test-wallet-0.json
# 读取方式：cat test-wallet-0.json | tr -d '\n'
TEST_WALLET_0=   # devnet 测试钱包 0（需预充值 0.1 SOL + 5000 MEME）
TEST_WALLET_1=   # devnet 测试钱包 1
TEST_WALLET_2=   # devnet 测试钱包 2
